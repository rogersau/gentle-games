{
  "name": "gentle-games",
  "version": "1.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --runInBand --coverage --watchAll=false",
    "test:single": "jest --runInBand",
    "test:i18n": "jest --testPathPattern=translationValidation",
    "typecheck": "tsc --noEmit",
    "ci:shared": "npm run test:ci && npm run typecheck",
    "ci:platform": "npm run build:web && npm run validate:android && npm run validate:ios",
    "ci:all": "npm run ci:shared && npm run ci:platform",
    "validate:android": "expo export --platform android --output-dir dist/android",
    "validate:ios": "expo export --platform ios --output-dir dist/ios",
    "build:web": "expo export --platform web --output-dir dist --clear",
    "build:pwa": "npm run build:web && node scripts/prepare-pwa.js",
    "build:android": "expo export --platform android --output-dir dist/android --clear",
    "build:ios": "expo export --platform ios --output-dir dist/ios --clear",
    "build:all": "npm run build:web && npm run build:android && npm run build:ios",
    "smoke:android:build": "npx expo prebuild --platform android --non-interactive --no-install --clean && cd android && ./gradlew assembleDebug --no-daemon",
    "smoke:android:install": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "smoke:android:test": "maestro test .maestro/smoke-home.yml",
    "smoke:android:ci": "npm run smoke:android:build && npm run smoke:android:install && npm run smoke:android:test",
    "upload:sourcemaps": "node scripts/upload-sourcemaps.js",
    "sentry:release": "npm run build:all && npm run upload:sourcemaps",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/metro-runtime": "^6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/stack": "^7.7.2",
    "@sentry/react-native": "^8.2.0",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-audio": "~1.1.1",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-localization": "~17.0.8",
    "expo-sensors": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25.8.13",
    "posthog-react-native": "^4.37.1",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-color-picker": "^0.6.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.12",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
